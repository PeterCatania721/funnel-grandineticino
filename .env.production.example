# Copia sul VPS come .env.funnel.production — NON committare.
# cp .env.funnel.production.example .env.funnel.production

DEBUG=False
SECRET_KEY=GENERA-CON-python-c-import-secrets-print-secrets-token-urlsafe-50

FUNNEL_MODE=true
FUNNEL_SEND_AUTORESPONSE=true

ALLOWED_HOSTS=grandineticino.ch,www.grandineticino.ch
CSRF_TRUSTED_ORIGINS=https://grandineticino.ch,https://www.grandineticino.ch

# SQLite nel volume grandineticino_data (isolato da kesi-site)
# DATABASE_URL=sqlite:////app/data/db.sqlite3

# --- Email Infomaniak (sempre info@kesi.biz) ---
# Password da Infisical (prod /): KESI_FUNNEL_GRANDINETICINO_EMAIL_PASSWORD
# In deploy: scripts/deploy-grandineticino.sh la mappa su EMAIL_HOST_PASSWORD.
EMAIL_HOST=mail.infomaniak.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@kesi.biz
EMAIL_HOST_PASSWORD=INSERISCI-PASSWORD-CASELLA
DEFAULT_FROM_EMAIL=info@kesi.biz
LEAD_RECIPIENT_EMAIL=info@kesi.biz
FUNNEL_RECIPIENT_EMAIL=info@kesi.biz
