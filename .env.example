# Copia in `.env.funnel` per il funnel locale. NON committare `.env.funnel`.

DEBUG=True
SECRET_KEY=django-insecure-funnel-dev-only

# Solo funnel (nessuna pagina del sito principale)
FUNNEL_MODE=true

ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,grandineticino.ch,www.grandineticino.ch
CSRF_TRUSTED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001,http://grandineticino.ch:8001

# Database SQLite isolato nel volume grandineticino_data
# DATABASE_URL=sqlite:////app/data/db.sqlite3

# --- Email (stesse credenziali del sito principale) ---
# Sviluppo senza password: console backend automatico se DEBUG=True.
EMAIL_HOST=mail.infomaniak.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@kesi.biz
# EMAIL_HOST_PASSWORD=   ← da Infisical: KESI_FUNNEL_GRANDINETICINO_EMAIL_PASSWORD
DEFAULT_FROM_EMAIL=info@kesi.biz
LEAD_RECIPIENT_EMAIL=info@kesi.biz
FUNNEL_RECIPIENT_EMAIL=info@kesi.biz
FUNNEL_SEND_AUTORESPONSE=true
